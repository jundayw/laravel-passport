{
    "name": "jundayw/passport",
    "description": "A lightweight and scalable PHP API request verification and response signature extension package.",
    "keywords": [
        "signature",
        "passport"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/jundayw/laravel-passport",
    "authors": [
        {
            "name": "jundayw",
            "email": "jundayw@126.com"
        }
    ],
    "require": {
        "php": "^8.0"
    },
    "require-dev": {
        "code-lts/doctum": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Jundayw\\Passport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "docs": "@php vendor/bin/doctum.php update doctum.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "3.x-dev"
        },
        "laravel": {
            "providers": [
                "Jundayw\\Passport\\PassportServiceProvider"
            ],
            "aliases": {
                "Token": "Jundayw\\Passport\\Facades\\Passport"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
